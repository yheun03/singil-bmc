{
    "name": "singil-bmc",
    "version": "0.0.1",
    "private": true,
    "homepage": "https://yheun03.github.io/singil-bmc/",
    "type": "module",
    "engines": {
        "node": ">=20 <23"
    },
    "scripts": {
        "build": "nuxt build",
        "clean": "rm -rf .nuxt .output node_modules/.vite",
        "dev:prepare": "npm run clean && npm run records:update && npm run generate:sitemap",
        "dev": "npm run dev:prepare && nuxt dev",
        "dev:only": "nuxt dev",
        "generate:sitemap": "node scripts/generate-sitemap.mjs",
        "generate": "npm run generate:sitemap && nuxt generate",
        "deploy": "NUXT_APP_BASE_URL=/singil-bmc/ npm run generate && gh-pages -d .output/public --dotfiles",
        "update": "node scripts/update-records.js",
        "records:parse": "node scripts/parse-game-html.js",
        "records:build": "node scripts/build-records.js",
        "records:sync": "npm run records:parse && npm run records:build",
        "records:update": "node scripts/update-records.js",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "sync:team": "node scripts/sync-team-repo.mjs",
        "sync:team:init": "node scripts/sync-team-repo.mjs --init"
    },
    "dependencies": {
        "@ag-grid-community/locale": "^33.3.2",
        "@iconify/vue": "^5.0.0",
        "@pinia/nuxt": "^0.5.4",
        "@toast-ui/editor": "^3.2.2",
        "ag-grid-community": "^33.3.2",
        "ag-grid-vue3": "^33.3.2",
        "axios": "^1.7.7",
        "chart.js": "^4.5.1",
        "flatpickr": "^4.6.13",
        "nouislider": "^15.8.1",
        "nuxt": "^3.14.1593",
        "pinia": "^2.2.4",
        "vue": "^3.5.12",
        "vue-chartjs": "^5.3.3",
        "vue-router": "^4.4.5",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@types/node": "^22.19.19",
        "cheerio": "^1.0.0",
        "gh-pages": "^6.3.0",
        "sass": "^1.80.4"
    }
}
